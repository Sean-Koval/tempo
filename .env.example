# Tempo — secrets template. Copy to .env and fill in.
# .env is gitignored; .env.example is committed.

# ---- intervals.icu ----
# Get from https://intervals.icu/settings under "Developer Settings".
INTERVALS_ATHLETE_ID=
INTERVALS_API_KEY=

# ---- Strava (Phase 3+) ----
# Create an app at https://www.strava.com/settings/api and follow the
# r-huijts/strava-mcp README for OAuth refresh-token setup.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
