# Tempo — secrets template. Copy to `.env` and fill in.
# `.env` is gitignored; `.env.example` is committed.
#
# Recommended loader: install direnv, then at repo root:
#     echo "dotenv" > .envrc
#     direnv allow
# direnv auto-exports these into your shell on cd-in. Both the `coach`
# CLI (via python-dotenv) and Claude Code's MCP spawn (via ${VAR}
# substitution in .claude/settings.json) then see them.
#
# Rotation: if any key leaks, revoke + regenerate in the service UI.
# Neither service uses username/password — only rotatable tokens.

# ---- intervals.icu ----
# Get from https://intervals.icu/settings (Developer section).
# Athlete ID is your profile URL slug, e.g. i123456.
INTERVALS_ICU_ATHLETE_ID=
INTERVALS_ICU_API_KEY=

# ---- Strava (Phase 3+) ----
# Create an app at https://www.strava.com/settings/api and follow the
# r-huijts/strava-mcp README for OAuth refresh-token setup. The refresh
# token rotates on each use — that's expected.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ---- Optional — override tempo's data dir (tests use this) ----
# TEMPO_DATA_DIR=/absolute/path/to/alt/data
