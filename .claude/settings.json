{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "intervals": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "./mcp-servers/intervals-icu-mcp",
        "intervals-mcp"
      ],
      "env": {
        "INTERVALS_ATHLETE_ID": "${INTERVALS_ATHLETE_ID}",
        "INTERVALS_API_KEY": "${INTERVALS_API_KEY}"
      }
    }
  },
  "_disabledMcpServers_phase3": {
    "strava": {
      "command": "npx",
      "args": ["-y", "@r-huijts/strava-mcp-server"],
      "env": {
        "STRAVA_CLIENT_ID": "${STRAVA_CLIENT_ID}",
        "STRAVA_CLIENT_SECRET": "${STRAVA_CLIENT_SECRET}",
        "STRAVA_REFRESH_TOKEN": "${STRAVA_REFRESH_TOKEN}"
      }
    },
    "coach-db": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "./mcp-servers/coach-db",
        "coach-db-mcp"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(sqlite3 data/coach.db:*)"
    ]
  }
}
