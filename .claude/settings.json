{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git submodule status:*)",
      "Bash(git submodule update:*)",
      "Bash(git submodule init:*)",
      "Bash(git submodule sync:*)",
      "Bash(git ls-files:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git -C:*)",
      "Bash(git worktree:*)",
      "Bash(bd ready)",
      "Bash(bd list:*)",
      "Bash(bd show:*)",
      "Bash(bd stats)",
      "Bash(bd blocked:*)",
      "Bash(bd create:*)",
      "Bash(bd update:*)",
      "Bash(bd close:*)",
      "Bash(bd dep:*)",
      "Bash(bd sync --flush-only)",
      "Bash(bd prime)",
      "Bash(make can-release)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make:*)",
      "Bash(sqlite3 data/coach.db:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(pre-commit run:*)",
      "Edit",
      "Write",
      "WebFetch(domain:intervals.icu)",
      "WebFetch(domain:developer.intervals.icu)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push:*main*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/worktree-bd-sync.sh"
          }
        ]
      }
    ]
  }
}
